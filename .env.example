# MariaDB - usa el mismo servidor que monkeyapp pero base de datos nueva
DB_HOST=tu-host-mariadb
DB_PORT=3306
DB_USER=tu-usuario
DB_PASSWORD=tu-password
DB_NAME=location_tracker

# VAPID Keys para Push Notifications (genera con: npm run generate-vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:tu-email@ejemplo.com

# Server
PORT=3000
